<%- include('../../partials/header') %>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white">
                    <h4 class="mb-0 text-dark">Tambah Data Siswa</h4>
                </div>
                <div class="card-body">
                    <form action="/admin/siswa/store" method="POST">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Username / NIS</label>
                            <input type="text" name="username" class="form-control bg-light" required placeholder="Contoh: 10293847">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Password</label>
                            <input type="password" name="password" class="form-control bg-light" required placeholder="Masukkan kata sandi">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Nama Lengkap</label>
                            <input type="text" name="nama_lengkap" class="form-control bg-light" required placeholder="Contoh: Budi Santoso">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Kelas</label>
                            <input type="text" name="kelas" class="form-control bg-light" required placeholder="Contoh: XII RPL 1">
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">No. HP / WhatsApp</label>
                            <input type="text" name="no_hp" class="form-control bg-light" placeholder="Contoh: 08123456789">
                        </div>
                        
                        <div class="d-flex justify-content-between">
                            <a href="/admin/siswa" class="btn btn-secondary">Batal</a>
                            <button type="submit" class="btn btn-primary">Simpan Siswa</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../../partials/footer') %>