<%- include('../../partials/header') %>

<style>
    .tabel-sempurna {
        border: 1px solid #212529;
        border-radius: 8px;
        overflow: hidden;
    }
    .tabel-sempurna table {
        margin-bottom: 0;
    }
    
    .tabel-sempurna th, .tabel-sempurna td {
        border: 1px solid #212529 !important; 
    }
    
    .tabel-sempurna tr:first-child th { border-top: none !important; }
    .tabel-sempurna tr:last-child td { border-bottom: none !important; }
    .tabel-sempurna th:first-child, .tabel-sempurna td:first-child { border-left: none !important; }
    .tabel-sempurna th:last-child, .tabel-sempurna td:last-child { border-right: none !important; }
</style>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-dark">Manajemen Siswa</h2>
        <div>
            <a href="/" class="btn btn-outline-secondary me-2">
                <i class="fas fa-home"></i> Dashboard
            </a>
            <a href="/admin/siswa/tambah" class="btn btn-primary">
                <i class="fas fa-plus"></i> Tambah Siswa
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive tabel-sempurna">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" class="text-center">No</th>
                            <th scope="col">Username / NIS</th>
                            <th scope="col">Nama Lengkap</th>
                            <th scope="col" class="text-center">Kelas</th>
                            <th scope="col">No. HP</th>
                            <th scope="col" class="text-center">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (siswa && siswa.length > 0) { %>
                            <% siswa.forEach((s, index) => { %>
                                <tr>
                                    <td class="text-center align-middle"><%= index + 1 %></td>
                                    <td class="align-middle fw-bold"><%= s.username %></td>
                                    <td class="align-middle"><%= s.nama_lengkap %></td>
                                    <td class="text-center align-middle"><span class="badge bg-secondary"><%= s.kelas %></span></td>
                                    <td class="align-middle"><%= s.no_hp || '-' %></td>
                                    <td class="text-center align-middle">
                                        <a href="/admin/siswa/edit/<%= s.id %>" class="btn btn-sm btn-outline-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <button class="btn btn-sm btn-outline-danger" onclick="confirmDelete('<%= s.id %>')" title="Hapus">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">Belum ada data siswa terdaftar.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function confirmDelete(id) {
        Swal.fire({
            title: 'Hapus Siswa?',
            text: "Data siswa beserta log kehadirannya akan dihapus permanen!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Ya, Hapus!',
            cancelButtonText: 'Batal'
        }).then((result) => {
            if (result.isConfirmed) {
                window.location.href = `/api/admin/siswa/delete/${id}`; 
            }
        })
    }

    const urlParams = new URLSearchParams(window.location.search);
    
    if (urlParams.get('status') === 'sukses') {
        Swal.fire({
            icon: 'success',
            title: 'Berhasil!',
            text: 'Data Siswa baru berhasil ditambahkan.',
            showConfirmButton: false,
            timer: 2000
        });
        window.history.replaceState(null, null, window.location.pathname);
        
    } else if (urlParams.get('status') === 'diperbarui') { 
        Swal.fire({
            icon: 'success',
            title: 'Diperbarui!',
            text: 'Perubahan data siswa berhasil disimpan.',
            showConfirmButton: false,
            timer: 2000
        });
        window.history.replaceState(null, null, window.location.pathname);
        
    } else if (urlParams.get('status') === 'dihapus') { 
        Swal.fire({
            icon: 'success',
            title: 'Terhapus!',
            text: 'Data Siswa telah dihapus secara permanen.',
            showConfirmButton: false,
            timer: 2000
        });
        window.history.replaceState(null, null, window.location.pathname);
    }
</script>

<%- include('../../partials/footer') %>