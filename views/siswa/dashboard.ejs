<%- include('../partials/header') %>

<%
  // Server-side calculation of presence operational window to avoid flash of loading states
  const parseTimeToSecondsServer = (timeStr) => {
    const parts = timeStr.split(':');
    return parseInt(parts[0]) * 3600 + parseInt(parts[1]) * 60 + (parseInt(parts[2]) || 0);
  };

  const nowServer = new Date();
  const currentSecondsServer = nowServer.getHours() * 3600 + nowServer.getMinutes() * 60 + nowServer.getSeconds();

  const sMasukMulai = parseTimeToSecondsServer(settings.jam_masuk_mulai);
  const sMasukSelesai = parseTimeToSecondsServer(settings.jam_masuk_selesai);
  const sPulangMulai = parseTimeToSecondsServer(settings.jam_pulang_mulai);
  const sPulangSelesai = parseTimeToSecondsServer(settings.jam_pulang_selesai);
%>

<div class="container py-2" style="max-width: 900px;">
  <!-- Bento Grid Content -->
  <div class="row g-3 mb-5">

    <!-- Bento Cell 1: Status Kehadiran Hari Ini (col-md-8) -->
    <div class="col-md-8">
      <div class="card border-0 shadow-sm bg-white h-100" style="border-radius: 16px;">
        <div class="card-body p-4 d-flex flex-column justify-content-center text-center min-vh-25">
          <% if (!todayPresensi) { %>
            <!-- Check-in entry state -->
            <%
              const tooEarly = currentSecondsServer < sMasukMulai;
              const tooLate = currentSecondsServer > sMasukSelesai;
              let iconClass = "fa-solid fa-user-clock text-warning fa-3x mb-3";
              let titleText = "Kehadiran Hari Ini Belum Dicatat";
              let descText = "Silakan tekan tombol di bawah untuk mengisi presensi masuk (hadir/izin/sakit).";
              let btnClass = "btn btn-primary btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm";
              let btnText = "<i class=\"fa-solid fa-fingerprint me-2\"></i> LAKUKAN PRESENSI MASUK";
              let btnHref = "/presensi/tambah";

              if (tooEarly) {
                iconClass = "fa-solid fa-clock text-secondary fa-3x mb-3";
                titleText = "Presensi Masuk Belum Dibuka";
                descText = `Waktu presensi masuk: ${settings.jam_masuk_mulai.substring(0, 5)} s/d ${settings.jam_masuk_selesai.substring(0, 5)} WIB.`;
                btnClass = "btn btn-secondary btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm disabled";
                btnText = "<i class=\"fa-solid fa-lock me-2\"></i> BELUM DIBUKA";
                btnHref = "javascript:void(0)";
              } else if (tooLate) {
                iconClass = "fa-solid fa-calendar-xmark text-danger fa-3x mb-3";
                titleText = "Presensi Masuk Ditutup";
                descText = `Batas waktu masuk hari ini adalah pukul ${settings.jam_masuk_selesai.substring(0, 5)} WIB.`;
                btnClass = "btn btn-danger btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm disabled";
                btnText = "<i class=\"fa-solid fa-lock me-2\"></i> MASUK DITUTUP";
                btnHref = "javascript:void(0)";
              }
            %>
            <div class="py-2" id="entry-state-container">
              <i id="entry-state-icon" class="<%= iconClass %>"></i>
              <div id="entry-state-text" class="mb-4">
                <h5 class="fw-bold text-dark mb-1"><%= titleText %></h5>
                <p class="text-secondary small mb-0"><%= descText %></p>
              </div>
              <a href="<%= btnHref %>" id="entry-state-button" class="<%= btnClass %>">
                <%- btnText %>
              </a>
            </div>

          <% } else if (todayPresensi.jenis_presensi === 'hadir' && !todayPresensi.waktu_pulang) { %>
            <!-- Check-out exit state -->
            <%
              const tooEarly = currentSecondsServer < sPulangMulai;
              const tooLate = currentSecondsServer > sPulangSelesai;
              let iconClass = "fa-solid fa-circle-exclamation text-primary fa-3x mb-3";
              let waktuMasukStr = new Date(todayPresensi.waktu_masuk).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
              let jarakMasukStr = todayPresensi.jarak_masuk ? Math.round(todayPresensi.jarak_masuk) + 'm' : '-';

              let descHtml = `<h5 class="fw-bold text-dark mb-1">Presensi Masuk Tercatat</h5>` +
                             `<p class="text-secondary small mb-2">Masuk pukul ${waktuMasukStr} WIB (Jarak: ${jarakMasukStr})</p>` +
                             `<p class="text-muted small mb-0">Silakan lakukan presensi pulang setelah kegiatan belajar mengajar berakhir.</p>`;
              let btnClass = "btn btn-success btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm";
              let btnText = "<i class=\"fa-solid fa-right-from-bracket me-2\"></i> LAKUKAN PRESENSI PULANG";
              let btnHref = "/presensi/tambah";

              if (tooEarly) {
                iconClass = "fa-solid fa-clock text-secondary fa-3x mb-3";
                descHtml = `<h5 class="fw-bold text-dark mb-1">Presensi Pulang Belum Dibuka</h5>` +
                           `<p class="text-secondary small mb-2">Masuk pukul ${waktuMasukStr} WIB (Jarak: ${jarakMasukStr})</p>` +
                           `<p class="text-muted small mb-0">Waktu presensi pulang: ${settings.jam_pulang_mulai.substring(0, 5)} s/d ${settings.jam_pulang_selesai.substring(0, 5)} WIB.</p>`;
                btnClass = "btn btn-secondary btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm disabled";
                btnText = "<i class=\"fa-solid fa-lock me-2\"></i> BELUM DIBUKA";
                btnHref = "javascript:void(0)";
              } else if (tooLate) {
                iconClass = "fa-solid fa-calendar-xmark text-danger fa-3x mb-3";
                descHtml = `<h5 class="fw-bold text-danger mb-1">Presensi Pulang Ditutup</h5>` +
                           `<p class="text-secondary small mb-2">Masuk pukul ${waktuMasukStr} WIB (Jarak: ${jarakMasukStr})</p>` +
                           `<p class="text-secondary small mb-0">Batas waktu presensi pulang hari ini adalah pukul ${settings.jam_pulang_selesai.substring(0, 5)} WIB.</p>`;
                btnClass = "btn btn-danger btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm disabled";
                btnText = "<i class=\"fa-solid fa-lock me-2\"></i> PULANG DITUTUP";
                btnHref = "javascript:void(0)";
              }
            %>
            <div class="py-2" id="exit-state-container">
              <i id="exit-state-icon" class="<%= iconClass %>"></i>
              <div id="exit-state-text" class="mb-4">
                <%- descHtml %>
              </div>
              <a href="<%= btnHref %>" id="exit-state-button" class="<%= btnClass %>">
                <%- btnText %>
              </a>
            </div>

          <% } else { %>
            <!-- Completed presence status display -->
            <div class="py-2">
              <i class="fa-solid fa-circle-check text-success fa-3x mb-3"></i>
              <h5 class="fw-bold text-success mb-1">Presensi Hari Ini Selesai</h5>
              <p class="text-secondary small mb-3">Data kehadiran Anda untuk hari ini sudah tersimpan dan terkunci.</p>

              <div class="bg-light rounded-3 p-3 text-start border small mx-auto" style="max-width: 500px;">
                <div class="d-flex justify-content-between mb-2">
                  <span class="text-muted">Status Kehadiran:</span>
                  <span class="fw-bold text-capitalize text-dark"><%= todayPresensi.jenis_presensi %></span>
                </div>
                <% if (todayPresensi.jenis_presensi === 'hadir') { %>
                  <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Waktu Masuk:</span>
                    <span class="fw-bold text-dark"><%= new Date(todayPresensi.waktu_masuk).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %> WIB</span>
                  </div>
                  <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Waktu Pulang:</span>
                    <span class="fw-bold text-dark"><%= todayPresensi.waktu_pulang ? new Date(todayPresensi.waktu_pulang).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) : '-' %> WIB</span>
                  </div>
                  <% if (todayPresensi.isi_jurnal) { %>
                    <div class="mt-2 pt-2 border-top">
                      <div class="text-muted mb-1">Jurnal Harian:</div>
                      <div class="text-dark bg-white p-2 rounded border text-wrap" style="word-break: break-all; white-space: pre-wrap;"><%= todayPresensi.isi_jurnal %></div>
                    </div>
                  <% } %>
                <% } else { %>
                  <div class="mt-2 pt-2 border-top">
                    <div class="text-muted mb-1">Keterangan Alasan:</div>
                    <div class="text-dark bg-white p-2 rounded border text-wrap" style="word-break: break-all; white-space: pre-wrap;"><%= todayPresensi.alasan_izin %></div>
                  </div>
                <% } %>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Bento Cell 2: Live Time & Greeting (col-md-4, bg-white & simplified) -->
    <div class="col-md-4">
      <div class="card border-0 shadow-sm bg-white h-100" style="border-radius: 16px; min-height: 180px;">
        <div class="card-body p-4 d-flex flex-column justify-content-between">
          <div>
            <div id="greeting-container" class="fs-5 fw-bold text-dark">
              <span id="greeting-text">Selamat Pagi</span>, <%= user.nama %>
            </div>
            <div class="text-muted small mt-1">
              Kelas: <strong class="text-dark"><%= user.kelas || '-' %></strong> &bull; NIS: <strong class="text-dark"><%= user.nomor_induk || '-' %></strong>
            </div>
          </div>
          <div class="mt-3">
            <div class="fw-bold fs-2 text-primary" id="live-time">--:--:--</div>
            <div class="text-muted small" id="live-date">-</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bento Cell 3: Statistik Kehadiran (col-md-4) -->
    <%
      let countHadir = 0;
      let countIzin = 0;
      let countSakit = 0;
      if (history) {
        history.forEach(log => {
          const type = (log.jenis_presensi || '').toLowerCase();
          if (type === 'hadir') countHadir++;
          else if (type === 'izin') countIzin++;
          else if (type === 'sakit') countSakit++;
        });
      }
    %>
    <div class="col-md-4">
      <div class="card border-0 shadow-sm bg-white h-100" style="border-radius: 16px;">
        <div class="card-body p-4 d-flex flex-column justify-content-between">
          <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-chart-simple text-primary me-2"></i>Statistik Saya</h6>

          <div class="d-flex align-items-center justify-content-between mb-2 p-2 bg-light rounded-3">
            <span class="small text-secondary fw-semibold">Hadir</span>
            <span class="badge bg-success-subtle text-success fw-bold px-3 py-2 fs-6" style="border-radius: 8px;"><%= countHadir %></span>
          </div>

          <div class="d-flex align-items-center justify-content-between mb-2 p-2 bg-light rounded-3">
            <span class="small text-secondary fw-semibold">Izin</span>
            <span class="badge bg-info-subtle text-info fw-bold px-3 py-2 fs-6" style="border-radius: 8px;"><%= countIzin %></span>
          </div>

          <div class="d-flex align-items-center justify-content-between p-2 bg-light rounded-3">
            <span class="small text-secondary fw-semibold">Sakit</span>
            <span class="badge bg-danger-subtle text-danger fw-bold px-3 py-2 fs-6" style="border-radius: 8px;"><%= countSakit %></span>
          </div>
        </div>
      </div>
    </div>

    <!-- Bento Cell 4: Parameter & Guidelines (col-md-8) -->
    <div class="col-md-8">
      <div class="card border-0 shadow-sm bg-white h-100" style="border-radius: 16px;">
        <div class="card-body p-4 d-flex flex-column justify-content-between">
          <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-circle-info text-primary me-2"></i>Panduan & Parameter Operasional</h6>
          <div class="row g-3 small text-secondary">
            <div class="col-sm-6">
              <div class="p-3 bg-light rounded-3 h-100">
                <div class="fw-bold text-dark mb-2"><i class="fa-solid fa-clock me-1 text-primary"></i> Waktu Presensi:</div>
                <div class="d-flex justify-content-between mb-1">
                  <span>Masuk:</span>
                  <span class="fw-semibold text-dark"><%= settings.jam_masuk_mulai.substring(0, 5) %> - <%= settings.jam_masuk_selesai.substring(0, 5) %> WIB</span>
                </div>
                <div class="d-flex justify-content-between">
                  <span>Pulang:</span>
                  <span class="fw-semibold text-dark"><%= settings.jam_pulang_mulai.substring(0, 5) %> - <%= settings.jam_pulang_selesai.substring(0, 5) %> WIB</span>
                </div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="p-3 bg-light rounded-3 h-100">
                <div class="fw-bold text-dark mb-2"><i class="fa-solid fa-circle-dot me-1 text-primary"></i> Aturan Posisi:</div>
                <p class="mb-0">
                  Siswa wajib berada dalam radius maksimal <strong><%= settings.radius_gps_meter %> meter</strong> dari koordinat sekolah untuk presensi Hadir.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bento Cell 5: Riwayat Kehadiran (col-12) -->
    <div class="col-12">
      <div class="card border-0 shadow-sm bg-white" style="border-radius: 16px;">
        <div class="card-header border-0 bg-transparent pt-4 px-4 pb-0 d-flex justify-content-between align-items-center">
          <h6 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-clock-rotate-left text-muted me-2"></i>Riwayat Kehadiran Terbaru</h6>
          <span class="badge bg-light text-dark border"><%= history.length > 5 ? '5 terbaru' : history.length + ' rekaman' %></span>
        </div>
        <div class="card-body p-3">
          <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0" style="font-size: 13.5px;">
              <thead class="table-light text-secondary small text-uppercase">
                <tr>
                  <th style="width: 35%;">Tanggal & Hari</th>
                  <th style="width: 25%;">Status</th>
                  <th style="width: 20%;">Masuk</th>
                  <th style="width: 20%;">Pulang</th>
                </tr>
              </thead>
              <tbody>
                <% if (history && history.length > 0) { %>
                  <% history.slice(0, 5).forEach(log => { %>
                    <%
                      const dateObj = new Date(log.created_at);
                      const formattedDate = dateObj.toLocaleDateString('id-ID', {
                        weekday: 'short',
                        day: 'numeric',
                        month: 'short',
                        year: 'numeric'
                      });
                    %>
                    <tr>
                      <td>
                        <span class="fw-semibold text-dark"><%= formattedDate %></span>
                      </td>
                      <td>
                        <% if (log.jenis_presensi === 'hadir' || log.jenis_presensi === 'Hadir') { %>
                          <span class="text-success fw-medium"><i class="fa-solid fa-circle-check me-1"></i>Hadir</span>
                        <% } else if (log.jenis_presensi === 'izin' || log.jenis_presensi === 'Izin') { %>
                          <span class="text-info fw-medium"><i class="fa-solid fa-file-signature me-1"></i>Izin</span>
                        <% } else if (log.jenis_presensi === 'sakit' || log.jenis_presensi === 'Sakit') { %>
                          <span class="text-danger fw-medium"><i class="fa-solid fa-head-side-virus me-1"></i>Sakit</span>
                        <% } else { %>
                          <span class="text-secondary text-capitalize fw-medium"><%= log.jenis_presensi %></span>
                        <% } %>
                      </td>
                      <td class="text-secondary">
                        <%= log.waktu_masuk ? new Date(log.waktu_masuk).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) : '-' %>
                      </td>
                      <td class="text-secondary">
                        <%= log.waktu_pulang ? new Date(log.waktu_pulang).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) : '-' %>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="4" class="text-center text-muted py-3">Belum ada riwayat presensi.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Timing parameters
  const jamMasukMulai = "<%= settings.jam_masuk_mulai %>";
  const jamMasukSelesai = "<%= settings.jam_masuk_selesai %>";
  const jamPulangMulai = "<%= settings.jam_pulang_mulai %>";
  const jamPulangSelesai = "<%= settings.jam_pulang_selesai %>";

  function parseTimeToSeconds(timeStr) {
    const parts = timeStr.split(':');
    return parseInt(parts[0]) * 3600 + parseInt(parts[1]) * 60 + (parseInt(parts[2]) || 0);
  }

  const secondsMasukMulai = parseTimeToSeconds(jamMasukMulai);
  const secondsMasukSelesai = parseTimeToSeconds(jamMasukSelesai);
  const secondsPulangMulai = parseTimeToSeconds(jamPulangMulai);
  const secondsPulangSelesai = parseTimeToSeconds(jamPulangSelesai);

  // Live Date/Time clock and Dynamic Greeting
  function startClock() {
    const liveTime = document.getElementById('live-time');
    const liveDate = document.getElementById('live-date');
    const greetingText = document.getElementById('greeting-text');
    const greetingContainer = document.getElementById('greeting-container');
    const optionsDate = { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' };
    const userName = "<%= user.nama %>";

    function updateTimeAndState() {
      const now = new Date();
      const currentSeconds = now.getHours() * 3600 + now.getMinutes() * 60 + now.getSeconds();

      if (liveTime) liveTime.innerText = now.toLocaleTimeString('id-ID') + ' WIB';
      if (liveDate) liveDate.innerText = now.toLocaleDateString('id-ID', optionsDate);

      // Update dynamic greeting text based on current hour
      if (greetingContainer && greetingText) {
        const hour = now.getHours();
        let greeting = "Selamat Malam";

        if (hour >= 5 && hour < 11) {
          greeting = "Selamat Pagi";
        } else if (hour >= 11 && hour < 15) {
          greeting = "Selamat Siang";
        } else if (hour >= 15 && hour < 18) {
          greeting = "Selamat Sore";
        }

        greetingContainer.innerHTML = `<span id="greeting-text" class="fw-bold">${greeting}</span>, ${userName}`;
      }

      // Check-in entry state display lock validation
      const entryStateContainer = document.getElementById('entry-state-container');
      if (entryStateContainer) {
        const tooEarly = currentSeconds < secondsMasukMulai;
        const tooLate = currentSeconds > secondsMasukSelesai;

        const iconEl = document.getElementById('entry-state-icon');
        const textEl = document.getElementById('entry-state-text');
        const buttonEl = document.getElementById('entry-state-button');

        if (tooEarly) {
          if (iconEl) iconEl.className = "fa-solid fa-clock text-secondary fa-3x mb-3";
          if (textEl) {
            textEl.innerHTML = `<h5 class="fw-bold text-dark mb-1">Presensi Masuk Belum Dibuka</h5>` +
                               `<p class="text-secondary small mb-0">Waktu presensi masuk: ${jamMasukMulai.substring(0, 5)} s/d ${jamMasukSelesai.substring(0, 5)} WIB.</p>`;
          }
          if (buttonEl) {
            buttonEl.className = "btn btn-secondary btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm disabled";
            buttonEl.innerHTML = `<i class="fa-solid fa-lock me-2"></i> BELUM DIBUKA`;
            buttonEl.setAttribute('href', 'javascript:void(0)');
          }
        } else if (tooLate) {
          if (iconEl) iconEl.className = "fa-solid fa-calendar-xmark text-danger fa-3x mb-3";
          if (textEl) {
            textEl.innerHTML = `<h5 class="fw-bold text-danger mb-1">Presensi Masuk Ditutup</h5>` +
                               `<p class="text-secondary small mb-0">Batas waktu masuk hari ini adalah pukul ${jamMasukSelesai.substring(0, 5)} WIB.</p>`;
          }
          if (buttonEl) {
            buttonEl.className = "btn btn-danger btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm disabled";
            buttonEl.innerHTML = `<i class="fa-solid fa-lock me-2"></i> MASUK DITUTUP`;
            buttonEl.setAttribute('href', 'javascript:void(0)');
          }
        } else {
          if (iconEl) iconEl.className = "fa-solid fa-user-clock text-warning fa-3x mb-3";
          if (textEl) {
            textEl.innerHTML = `<h5 class="fw-bold text-dark mb-1">Kehadiran Hari Ini Belum Dicatat</h5>` +
                               `<p class="text-secondary small mb-0">Silakan tekan tombol di bawah untuk mengisi presensi masuk.</p>`;
          }
          if (buttonEl) {
            buttonEl.className = "btn btn-primary btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm";
            buttonEl.innerHTML = `<i class="fa-solid fa-fingerprint me-2"></i> LAKUKAN PRESENSI MASUK`;
            buttonEl.setAttribute('href', '/presensi/tambah');
          }
        }
      }

      // Check-out exit state display lock validation
      const exitStateContainer = document.getElementById('exit-state-container');
      if (exitStateContainer) {
        const tooEarly = currentSeconds < secondsPulangMulai;
        const tooLate = currentSeconds > secondsPulangSelesai;

        const iconEl = document.getElementById('exit-state-icon');
        const textEl = document.getElementById('exit-state-text');
        const buttonEl = document.getElementById('exit-state-button');
        const waktuMasukStr = "<%= todayPresensi && todayPresensi.waktu_masuk ? new Date(todayPresensi.waktu_masuk).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) : '' %>";
        const jarakMasukStr = "<%= todayPresensi && todayPresensi.jarak_masuk ? Math.round(todayPresensi.jarak_masuk) + 'm' : '-' %>";

        if (tooEarly) {
          if (iconEl) iconEl.className = "fa-solid fa-clock text-secondary fa-3x mb-3";
          if (textEl) {
            textEl.innerHTML = `<h5 class="fw-bold text-dark mb-1">Presensi Pulang Belum Dibuka</h5>` +
                               `<p class="text-secondary small mb-2">Masuk pukul ${waktuMasukStr} WIB (Jarak: ${jarakMasukStr})</p>` +
                               `<p class="text-muted small mb-0">Waktu presensi pulang: ${jamPulangMulai.substring(0, 5)} s/d ${jamPulangSelesai.substring(0, 5)} WIB.</p>`;
          }
          if (buttonEl) {
            buttonEl.className = "btn btn-secondary btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm disabled";
            buttonEl.innerHTML = `<i class="fa-solid fa-lock me-2"></i> BELUM DIBUKA`;
            buttonEl.setAttribute('href', 'javascript:void(0)');
          }
        } else if (tooLate) {
          if (iconEl) iconEl.className = "fa-solid fa-calendar-xmark text-danger fa-3x mb-3";
          if (textEl) {
            textEl.innerHTML = `<h5 class="fw-bold text-danger mb-1">Presensi Pulang Ditutup</h5>` +
                               `<p class="text-secondary small mb-2">Masuk pukul ${waktuMasukStr} WIB (Jarak: ${jarakMasukStr})</p>` +
                               `<p class="text-secondary small mb-0">Batas waktu presensi pulang hari ini adalah pukul ${jamPulangSelesai.substring(0, 5)} WIB.</p>`;
          }
          if (buttonEl) {
            buttonEl.className = "btn btn-danger btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm disabled";
            buttonEl.innerHTML = `<i class="fa-solid fa-lock me-2"></i> PULANG DITUTUP`;
            buttonEl.setAttribute('href', 'javascript:void(0)');
          }
        } else {
          if (iconEl) iconEl.className = "fa-solid fa-circle-exclamation text-primary fa-3x mb-3";
          if (textEl) {
            textEl.innerHTML = `<h5 class="fw-bold text-dark mb-1">Presensi Masuk Tercatat</h5>` +
                               `<p class="text-secondary small mb-2">Masuk pukul ${waktuMasukStr} WIB (Jarak: ${jarakMasukStr})</p>` +
                               `<p class="text-muted small mb-0">Silakan lakukan presensi pulang sebelum waktu berakhir.</p>`;
          }
          if (buttonEl) {
            buttonEl.className = "btn btn-success btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm";
            buttonEl.innerHTML = `<i class="fa-solid fa-right-from-bracket me-2"></i> LAKUKAN PRESENSI PULANG`;
            buttonEl.setAttribute('href', '/presensi/tambah');
          }
        }
      }
    }

    // Call immediately to avoid 1-second delay
    updateTimeAndState();

    // Interval ticker loop
    setInterval(updateTimeAndState, 1000);
  }
  startClock();
</script>

