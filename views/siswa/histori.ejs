<%- include('../partials/header') %>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Header Halaman -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="text-dark">Histori Presensi Saya</h2>
                <a href="/siswa/dashboard" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Kembali
                </a>
            </div>

            <!-- Kartu Tabel Histori -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom">
                    <h5 class="mb-0 text-dark">Log Riwayat Kehadiran Individu</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col" class="text-center">No</th>
                                    <th scope="col">Tanggal</th>
                                    <th scope="col" class="text-center">Jam Masuk</th>
                                    <th scope="col" class="text-center">Jam Pulang</th>
                                    <th scope="col" class="text-center">Status</th>
                                    <th scope="col">Jurnal Harian</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Looping data histori dari controller backend menggunakan EJS -->
                                <% if (histori && histori.length > 0) { %>
                                    <% histori.forEach((data, index) => { %>
                                        <tr>
                                            <td class="text-center align-middle"><%= index + 1 %></td>
                                            <td class="align-middle">
                                                <!-- Asumsi format tanggal diformat di controller atau menggunakan method toLocaleDateString -->
                                                <%= new Date(data.tanggal).toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
                                            </td>
                                            <td class="text-center align-middle">
                                                <span class="badge bg-secondary"><%= data.jam_masuk || '--:--' %></span>
                                            </td>
                                            <td class="text-center align-middle">
                                                <span class="badge bg-secondary"><%= data.jam_pulang || '--:--' %></span>
                                            </td>
                                            <td class="text-center align-middle">
                                                <!-- Logika pewarnaan badge berdasarkan status kehadiran -->
                                                <% if (data.status === 'Hadir') { %>
                                                    <span class="badge bg-success">Hadir (GPS)</span>
                                                <% } else if (data.status === 'Sakit') { %>
                                                    <span class="badge bg-warning text-dark">Sakit</span>
                                                <% } else if (data.status === 'Izin') { %>
                                                    <span class="badge bg-info text-dark">Izin</span>
                                                <% } else { %>
                                                    <span class="badge bg-danger">Alpa</span>
                                                <% } %>
                                            </td>
                                            <td class="align-middle text-truncate" style="max-width: 200px;">
                                                <!-- Menampilkan teks jurnal atau strip jika kosong -->
                                                <%= data.jurnal || '-' %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">
                                            <i class="fas fa-folder-open fa-2x mb-2 d-block"></i>
                                            Belum ada data histori presensi.
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            
        </div>
    </div>
</div>

<%- include('../partials/footer') %>