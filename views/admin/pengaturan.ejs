<%- include('../partials/header') %>
<!-- Leaflet CSS & JS via CDN -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<!-- SweetAlert2 for notifications -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<div class="row justify-content-center my-4">
  <div class="col-md-8">
    <div class="card shadow-sm border-0 p-4 bg-white text-dark">
      <div class="card-header border-0 bg-transparent pb-3">
        <h4 class="mb-0 fw-bold text-primary"><i class="fa-solid fa-gears me-2"></i>Pengaturan Sistem Presensi</h4>
      </div>
      
      <div class="card-body">
        <form id="settingsForm">
          
          <h5 class="fw-bold mb-3"><i class="fa-solid fa-clock me-2 text-secondary"></i>Waktu Operasional Presensi</h5>
          <div class="row mb-3">
            <div class="col-md-6 mb-3">
              <label for="jam_masuk_mulai" class="form-label text-muted small fw-semibold">Jam Masuk Mulai</label>
              <input type="time" class="form-control" id="jam_masuk_mulai" name="jam_masuk_mulai" value="<%= settings.jam_masuk_mulai %>" required>
            </div>
            <div class="col-md-6 mb-3">
              <label for="jam_masuk_selesai" class="form-label text-muted small fw-semibold">Jam Masuk Selesai</label>
              <input type="time" class="form-control" id="jam_masuk_selesai" name="jam_masuk_selesai" value="<%= settings.jam_masuk_selesai %>" required>
            </div>
          </div>
          
          <div class="row mb-4">
            <div class="col-md-6 mb-3">
              <label for="jam_pulang_mulai" class="form-label text-muted small fw-semibold">Jam Pulang Mulai</label>
              <input type="time" class="form-control" id="jam_pulang_mulai" name="jam_pulang_mulai" value="<%= settings.jam_pulang_mulai %>" required>
            </div>
            <div class="col-md-6 mb-3">
              <label for="jam_pulang_selesai" class="form-label text-muted small fw-semibold">Jam Pulang Selesai</label>
              <input type="time" class="form-control" id="jam_pulang_selesai" name="jam_pulang_selesai" value="<%= settings.jam_pulang_selesai %>" required>
            </div>
          </div>

          <hr class="my-4">

          <h5 class="fw-bold mb-3"><i class="fa-solid fa-location-dot me-2 text-secondary"></i>Parameter Lokasi & GPS</h5>
          
          <div class="mb-3">
            <label for="radius_gps_meter" class="form-label text-muted small fw-semibold">Radius GPS Validasi (meter)</label>
            <input type="number" class="form-control" id="radius_gps_meter" name="radius_gps_meter" value="<%= settings.radius_gps_meter %>" min="10" max="5000" required>
            <div class="form-text">Batas radius maksimal siswa terhadap titik koordinat sekolah (dalam meter).</div>
          </div>

          <!-- Leaflet Map Container -->
          <div class="mb-3">
            <label class="form-label text-muted small fw-semibold">Mapping Lokasi Sekolah (Klik Peta / Geser Pin)</label>
            <div id="map" style="height: 350px; z-index: 1;" class="rounded border shadow-sm mb-2"></div>
            <div class="form-text text-muted">Secara default, peta dipusatkan di Universitas Muria Kudus. Klik peta atau geser pin biru untuk memindahkan lokasi sekolah.</div>
          </div>

          <div class="row align-items-end">
            <div class="col-md-5 mb-3">
              <label for="latitude_sekolah" class="form-label text-muted small fw-semibold">Latitude Sekolah</label>
              <input type="number" step="any" class="form-control" id="latitude_sekolah" name="latitude_sekolah" value="<%= settings.latitude_sekolah %>" required>
            </div>
            <div class="col-md-5 mb-3">
              <label for="longitude_sekolah" class="form-label text-muted small fw-semibold">Longitude Sekolah</label>
              <input type="number" step="any" class="form-control" id="longitude_sekolah" name="longitude_sekolah" value="<%= settings.longitude_sekolah %>" required>
            </div>
            <div class="col-md-2 mb-3">
              <button type="button" class="btn btn-outline-secondary w-100" onclick="getCurrentLocation()" title="Ambil koordinat GPS aktif gawai Anda">
                <i class="fa-solid fa-location-crosshairs"></i> Get
              </button>
            </div>
          </div>

          <div class="d-flex justify-content-end gap-2 mt-4">
            <a href="/" class="btn btn-outline-secondary px-4"><i class="fa-solid fa-arrow-left me-2"></i>Kembali</a>
            <button type="submit" class="btn btn-primary px-4"><i class="fa-solid fa-floppy-disk me-2"></i>Simpan Pengaturan</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  // Center default: Universitas Muria Kudus (UMK)
  let defaultLat = -6.793208;
  let defaultLng = 110.865485;

  // Read saved coordinates from database if they exist
  const savedLat = parseFloat("<%= settings.latitude_sekolah %>");
  const savedLng = parseFloat("<%= settings.longitude_sekolah %>");

  if (!isNaN(savedLat) && !isNaN(savedLng) && savedLat !== 0 && savedLng !== 0) {
    defaultLat = savedLat;
    defaultLng = savedLng;
  }

  // Initialize Leaflet Map centered at default coords
  const map = L.map('map').setView([defaultLat, defaultLng], 16);

  // Add OpenStreetMap tile layer
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
    attribution: '© OpenStreetMap contributors'
  }).addTo(map);

  // Add Draggable Marker to selected location
  const marker = L.marker([defaultLat, defaultLng], {
    draggable: true
  }).addTo(map);

  // Helper to sync inputs with coordinates
  function updateLatLngInputs(lat, lng) {
    document.getElementById('latitude_sekolah').value = lat.toFixed(8);
    document.getElementById('longitude_sekolah').value = lng.toFixed(8);
  }

  // Sync inputs when marker is dragged
  marker.on('dragend', function (e) {
    const position = marker.getLatLng();
    updateLatLngInputs(position.lat, position.lng);
  });

  // Click on map to place marker and sync inputs
  map.on('click', function (e) {
    marker.setLatLng(e.latlng);
    updateLatLngInputs(e.latlng.lat, e.latlng.lng);
  });

  // Sync Leaflet map when using device GPS location
  function updateMapLocation(lat, lng) {
    marker.setLatLng([lat, lng]);
    map.setView([lat, lng], 17);
    updateLatLngInputs(lat, lng);
  }

  function getCurrentLocation() {
    if (!navigator.geolocation) {
      Swal.fire({
        icon: 'error',
        title: 'Gagal',
        text: 'Browser Anda tidak mendukung pengambilan lokasi.'
      });
      return;
    }

    Swal.fire({
      title: 'Mendeteksi Lokasi...',
      text: 'Harap berikan izin akses lokasi jika diminta.',
      allowOutsideClick: false,
      didOpen: () => {
        Swal.showLoading();
      }
    });

    navigator.geolocation.getCurrentPosition(
      (position) => {
        const lat = position.coords.latitude;
        const lng = position.coords.longitude;
        updateMapLocation(lat, lng);
        Swal.fire({
          icon: 'success',
          title: 'Lokasi Ditemukan',
          text: `Koordinat berhasil dipasang: ${lat.toFixed(6)}, ${lng.toFixed(6)}`
        });
      },
      (error) => {
        Swal.fire({
          icon: 'error',
          title: 'Gagal',
          text: error.message || 'Izin akses lokasi ditolak.'
        });
      },
      { enableHighAccuracy: true, timeout: 10000 }
    );
  }

  document.getElementById('settingsForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const jam_masuk_mulai = document.getElementById('jam_masuk_mulai').value;
    const jam_masuk_selesai = document.getElementById('jam_masuk_selesai').value;
    const jam_pulang_mulai = document.getElementById('jam_pulang_mulai').value;
    const jam_pulang_selesai = document.getElementById('jam_pulang_selesai').value;
    const radius_gps_meter = document.getElementById('radius_gps_meter').value;
    const latitude_sekolah = document.getElementById('latitude_sekolah').value;
    const longitude_sekolah = document.getElementById('longitude_sekolah').value;

    try {
      const response = await fetch('/api/admin/pengaturan', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          jam_masuk_mulai,
          jam_masuk_selesai,
          jam_pulang_mulai,
          jam_pulang_selesai,
          radius_gps_meter,
          latitude_sekolah,
          longitude_sekolah
        })
      });

      const result = await response.json();

      if (response.ok) {
        Swal.fire({
          icon: 'success',
          title: 'Berhasil',
          text: 'Pengaturan sistem berhasil diperbarui!'
        }).then(() => {
          window.location.reload();
        });
      } else {
        throw new Error(result.message || 'Gagal menyimpan pengaturan.');
      }
    } catch (error) {
      Swal.fire({
        icon: 'error',
        title: 'Error',
        text: error.message
      });
    }
  });
</script>
<%- include('../partials/footer') %>
