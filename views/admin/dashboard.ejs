<%- include('../partials/header') %>

<%
  const now = new Date();
  const hour = now.getHours();
  let greeting = "Selamat Malam";
  if (hour >= 5 && hour < 11) {
    greeting = "Selamat Pagi";
  } else if (hour >= 11 && hour < 15) {
    greeting = "Selamat Siang";
  } else if (hour >= 15 && hour < 18) {
    greeting = "Selamat Sore";
  }
%>

<div class="container py-2" style="max-width: 900px;">
  <!-- Bento Grid Content -->
  <div class="row g-3 mb-5">

    <!-- Bento Cell 1: Admin Greeting & Quick Info (col-md-8) -->
    <div class="col-md-8">
      <div class="card border-0 shadow-sm bg-white h-100" style="border-radius: 16px;">
        <div class="card-body p-4 d-flex flex-column justify-content-center min-vh-25">
          <div class="d-flex align-items-center mb-3">
            <h4 class="fw-bold mb-0 text-dark"><%= greeting %>, <%= user.nama %></h4>
          </div>
          <p class="text-secondary small mb-0">
            Sekarang <strong><%= now.toLocaleDateString('id-ID', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %></strong>. Karena kamu admin, Kamu berkuasa dan admin selalu benar saat bertindak.
          </p>
        </div>
      </div>
    </div>

    <!-- Bento Cell 2: Total Siswa Card (col-md-4) -->
    <div class="col-md-4">
      <div class="card border-0 shadow-sm bg-white h-100" style="border-radius: 16px; min-height: 180px;">
        <div class="card-body p-4 d-flex flex-column justify-content-between">
          <div class="d-flex justify-content-between align-items-center">
            <span class="text-secondary fw-semibold small">Data Pengguna</span>
            <i class="fa-solid fa-users text-primary fs-4"></i>
          </div>
          <div>
            <div class="fw-bold text-dark fs-1"><%= stats.totalSiswa %></div>
            <div class="text-muted small">Total Siswa Terdaftar</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats Cards for Hadir, Izin, Sakit, Alpha -->
    <!-- Bento Cell 3: Hadir Card -->
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 shadow-sm bg-white h-100" style="border-radius: 16px;">
        <div class="card-body p-3 d-flex flex-column justify-content-between">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-secondary fw-semibold small">Hadir Hari Ini</span>
            <div class="bg-success-subtle rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
              <i class="fa-solid fa-user-check text-success small"></i>
            </div>
          </div>
          <div>
            <div class="fw-bold text-success fs-2"><%= stats.totalHadir %></div>
            <div class="text-muted small">Siswa Hadir (GPS)</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bento Cell 4: Izin Card -->
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 shadow-sm bg-white h-100" style="border-radius: 16px;">
        <div class="card-body p-3 d-flex flex-column justify-content-between">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-secondary fw-semibold small">Izin Hari Ini</span>
            <div class="bg-info-subtle rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
              <i class="fa-solid fa-file-signature text-info small"></i>
            </div>
          </div>
          <div>
            <div class="fw-bold text-info fs-2"><%= stats.totalIzin %></div>
            <div class="text-muted small">Siswa Izin Masuk</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bento Cell 5: Sakit Card -->
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 shadow-sm bg-white h-100" style="border-radius: 16px;">
        <div class="card-body p-3 d-flex flex-column justify-content-between">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-secondary fw-semibold small">Sakit Hari Ini</span>
            <div class="bg-warning-subtle rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
              <i class="fa-solid fa-head-side-virus text-warning small"></i>
            </div>
          </div>
          <div>
            <div class="fw-bold text-warning fs-2"><%= stats.totalSakit %></div>
            <div class="text-muted small">Siswa Sakit</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bento Cell 6: Alpa Card -->
    <div class="col-md-3 col-sm-6">
      <div class="card border-0 shadow-sm bg-white h-100" style="border-radius: 16px;">
        <div class="card-body p-3 d-flex flex-column justify-content-between">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-secondary fw-semibold small">Alpa Hari Ini</span>
            <div class="bg-danger-subtle rounded-circle p-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
              <i class="fa-solid fa-user-xmark text-danger small"></i>
            </div>
          </div>
          <div>
            <div class="fw-bold text-danger fs-2"><%= stats.totalAlpa %></div>
            <div class="text-muted small">Alpa / Belum Presensi</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bento Cell 7: Configuration Active (col-md-12) -->
    <div class="col-md-12">
      <div class="card border-0 shadow-sm bg-white" style="border-radius: 16px;">
        <div class="card-body p-4">
          <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-gears text-primary me-2"></i>Konfigurasi Sistem Aktif</h6>
          <div class="row g-3 small text-secondary">
            <div class="col-sm-6">
              <div class="p-3 bg-light rounded-3 h-100">
                <div class="fw-bold text-dark mb-2"><i class="fa-solid fa-clock me-1 text-primary"></i> Waktu Operasional:</div>
                <div class="d-flex justify-content-between mb-1">
                  <span>Masuk:</span>
                  <span class="fw-semibold text-dark"><%= settings.jam_masuk_mulai.substring(0, 5) %> - <%= settings.jam_masuk_selesai.substring(0, 5) %> WIB</span>
                </div>
                <div class="d-flex justify-content-between">
                  <span>Pulang:</span>
                  <span class="fw-semibold text-dark"><%= settings.jam_pulang_mulai.substring(0, 5) %> - <%= settings.jam_pulang_selesai.substring(0, 5) %> WIB</span>
                </div>
              </div>
            </div>
            <div class="col-sm-6">
              <div class="p-3 bg-light rounded-3 h-100">
                <div class="fw-bold text-dark mb-2"><i class="fa-solid fa-circle-dot me-1 text-primary"></i> Validasi GPS:</div>
                <p class="mb-0">
                  Radius toleransi: <strong><%= settings.radius_gps_meter %> meter</strong> dari koordinat sekolah <code><%= parseFloat(settings.latitude_sekolah).toFixed(6) %>, <%= parseFloat(settings.longitude_sekolah).toFixed(6) %></code>.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Bento Cell 8: Riwayat Kehadiran Terbaru (col-12) -->
    <div class="col-12">
      <div class="card border-0 shadow-sm bg-white" style="border-radius: 16px;">
        <div class="card-header border-0 bg-transparent pt-4 px-4 pb-0 d-flex justify-content-between align-items-center">
          <h6 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-clock-rotate-left text-muted me-2"></i>10 Aktivitas Presensi Terbaru</h6>
          <span class="badge bg-light text-dark border">Terbaru</span>
        </div>
        <div class="card-body p-3">
          <div class="table-responsive">
            <table class="table table-sm table-hover align-middle mb-0" style="font-size: 13.5px;">
              <thead class="table-light text-secondary small text-uppercase">
                <tr>
                  <th style="width: 5%;" class="text-center">No</th>
                  <th style="width: 25%;">Nama Siswa</th>
                  <th style="width: 15%;" class="text-center">Kelas</th>
                  <th style="width: 15%;" class="text-center">Status</th>
                  <th style="width: 20%;" class="text-center">Waktu Masuk</th>
                  <th style="width: 20%;" class="text-center">Waktu Pulang</th>
                </tr>
              </thead>
              <tbody>
                <% if (recentPresensi && recentPresensi.length > 0) { %>
                  <% recentPresensi.forEach((log, index) => { %>
                    <tr>
                      <td class="text-center text-secondary"><%= index + 1 %></td>
                      <td>
                        <span class="fw-semibold text-dark"><%= log.nama_siswa %></span>
                      </td>
                      <td class="text-center text-secondary"><%= log.kelas || '-' %></td>
                      <td class="text-center">
                        <% if (log.jenis_presensi === 'hadir' || log.jenis_presensi === 'Hadir') { %>
                          <span class="text-success fw-medium"><i class="fa-solid fa-circle-check me-1"></i>Hadir</span>
                        <% } else if (log.jenis_presensi === 'izin' || log.jenis_presensi === 'Izin') { %>
                          <span class="text-info fw-medium"><i class="fa-solid fa-file-signature me-1"></i>Izin</span>
                        <% } else if (log.jenis_presensi === 'sakit' || log.jenis_presensi === 'Sakit') { %>
                          <span class="text-danger fw-medium"><i class="fa-solid fa-head-side-virus me-1"></i>Sakit</span>
                        <% } else { %>
                          <span class="text-secondary text-capitalize fw-medium"><%= log.jenis_presensi %></span>
                        <% } %>
                      </td>
                      <td class="text-secondary text-center">
                        <%= log.waktu_masuk ? new Date(log.waktu_masuk).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) + ' WIB' : '-' %>
                      </td>
                      <td class="text-secondary text-center">
                        <%= log.waktu_pulang ? new Date(log.waktu_pulang).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) + ' WIB' : '-' %>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="6" class="text-center text-muted py-3">Belum ada aktivitas presensi terbaru.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
