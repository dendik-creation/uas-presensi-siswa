<%- include('../../partials/header') %>

<!-- Leaflet.js CDN -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<div class="container py-2" style="max-width: 1000px;">
  <!-- Breadcrumb & Header -->
  <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
    <div>
      <h4 class="fw-bold mb-0 text-primary"><i class="fa-solid fa-map-location-dot me-2"></i> Detail Presensi</h4>
      <p class="text-muted mb-0 small">Verifikasi Lokasi & Jurnal Harian Siswa</p>
    </div>
    <div>
      <a href="/admin/presensi" class="btn btn-outline-secondary fw-semibold rounded-pill">
        <i class="fa-solid fa-arrow-left me-1"></i> Kembali
      </a>
    </div>
  </div>

  <div class="row g-4 mb-5">
    <!-- Left Column: Student Details & Check Log -->
    <div class="col-md-5">
      <!-- Student Info Card -->
      <div class="card border-0 shadow-sm bg-white mb-4" style="border-radius: 16px;">
        <div class="card-body p-4">
          <div class="d-flex align-items-center mb-3">
            <div class="bg-primary-subtle text-primary rounded-circle p-3 d-flex align-items-center justify-content-center me-3" style="width: 54px; height: 54px;">
              <i class="fa-solid fa-user-graduate fs-4"></i>
            </div>
            <div>
              <h5 class="fw-bold text-dark mb-0"><%= log.nama_siswa %></h5>
              <span class="text-muted small">Kelas: <strong><%= log.kelas || '-' %></strong> &bull; NIS: <strong><%= log.nomor_induk || '-' %></strong></span>
            </div>
          </div>
          
          <div class="border-top pt-3 text-secondary small">
            <div class="d-flex justify-content-between mb-2">
              <span>Nomor Kontak:</span>
              <span class="fw-semibold text-dark"><%= log.no_hp || '-' %></span>
            </div>
            <div class="d-flex justify-content-between">
              <span>Tanggal Presensi:</span>
              <span class="fw-semibold text-dark">
                <%= new Date(log.created_at).toLocaleDateString('id-ID', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }) %>
              </span>
            </div>
          </div>
        </div>
      </div>

      <!-- Log Details Card -->
      <div class="card border-0 shadow-sm bg-white mb-4" style="border-radius: 16px;">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="fw-bold text-dark mb-0"><i class="fa-solid fa-circle-info text-primary me-2"></i>Status Kehadiran</h6>
            <% if (log.jenis_presensi === 'hadir' || log.jenis_presensi === 'Hadir') { %>
              <span class="badge bg-success-subtle text-success px-3 py-2 fw-bold" style="border-radius: 8px;"><i class="fa-solid fa-circle-check me-1"></i>Hadir</span>
            <% } else if (log.jenis_presensi === 'izin' || log.jenis_presensi === 'Izin') { %>
              <span class="badge bg-info-subtle text-info px-3 py-2 fw-bold" style="border-radius: 8px;"><i class="fa-solid fa-file-signature me-1"></i>Izin</span>
            <% } else if (log.jenis_presensi === 'sakit' || log.jenis_presensi === 'Sakit') { %>
              <span class="badge bg-warning-subtle text-warning px-3 py-2 fw-bold" style="border-radius: 8px;"><i class="fa-solid fa-head-side-virus me-1"></i>Sakit</span>
            <% } else { %>
              <span class="badge bg-danger-subtle text-danger px-3 py-2 fw-bold" style="border-radius: 8px;"><i class="fa-solid fa-user-xmark me-1"></i>Alpa</span>
            <% } %>
          </div>

          <!-- Time Check Logs -->
          <div class="p-3 bg-light rounded-3 mb-3 small text-secondary">
            <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
              <span class="fw-semibold text-dark"><i class="fa-solid fa-right-to-bracket text-success me-1"></i> Waktu Masuk:</span>
              <span class="fw-bold text-dark"><%= log.waktu_masuk ? new Date(log.waktu_masuk).toLocaleTimeString('id-ID') + ' WIB' : '-' %></span>
            </div>
            <div class="d-flex justify-content-between">
              <span class="fw-semibold text-dark"><i class="fa-solid fa-right-from-bracket text-danger me-1"></i> Waktu Pulang:</span>
              <span class="fw-bold text-dark"><%= log.waktu_pulang ? new Date(log.waktu_pulang).toLocaleTimeString('id-ID') + ' WIB' : '-' %></span>
            </div>
          </div>

          <!-- GPS Validation Metrics -->
          <% if (log.jenis_presensi === 'hadir') { %>
            <div class="p-3 bg-light rounded-3 mb-3 small text-secondary">
              <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
                <span><i class="fa-solid fa-street-view me-1 text-primary"></i> Jarak GPS Masuk:</span>
                <span class="fw-bold text-dark"><%= log.jarak_masuk ? Math.round(log.jarak_masuk) + ' meter' : '-' %></span>
              </div>
              <div class="d-flex justify-content-between">
                <span><i class="fa-solid fa-street-view me-1 text-primary"></i> Jarak GPS Pulang:</span>
                <span class="fw-bold text-dark"><%= log.jarak_pulang ? Math.round(log.jarak_pulang) + ' meter' : '-' %></span>
              </div>
            </div>
          <% } %>

          <!-- Journal or Reason -->
          <% if (log.jenis_presensi === 'hadir') { %>
            <div class="mt-3">
              <span class="small fw-bold text-secondary d-block mb-1"><i class="fa-solid fa-book-open text-primary me-1"></i> Jurnal Harian Siswa:</span>
              <div class="bg-light p-3 rounded-3 border text-dark small text-wrap" style="word-break: break-all; white-space: pre-wrap;"><%= log.isi_jurnal || 'Siswa belum memasukkan jurnal harian.' %></div>
            </div>
          <% } else { %>
            <div class="mt-3">
              <span class="small fw-bold text-secondary d-block mb-1"><i class="fa-solid fa-note-sticky text-primary me-1"></i> Keterangan Alasan:</span>
              <div class="bg-light p-3 rounded-3 border text-dark small text-wrap" style="word-break: break-all; white-space: pre-wrap;"><%= log.alasan_izin || '-' %></div>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Right Column: Interactive Map -->
    <div class="col-md-7">
      <div class="card border-0 shadow-sm bg-white h-100" style="border-radius: 16px; min-height: 450px;">
        <div class="card-header border-0 bg-transparent pt-4 px-4 pb-0">
          <h6 class="fw-bold text-dark mb-0"><i class="fa-solid fa-map text-primary me-2"></i>Peta Lokasi Presensi</h6>
        </div>
        <div class="card-body p-4 d-flex flex-column">
          <!-- Interactive Map Container -->
          <div id="detailMap" class="flex-grow-1 border rounded-3 mb-3" style="min-height: 380px;"></div>
          
          <div class="small text-secondary">
            <i class="fa-solid fa-circle-info text-primary me-1"></i>
            Lingkaran biru mewakili radius sekolah toleransi GPS aktif sebesar <strong><%= settings.radius_gps_meter %> meter</strong>.
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // School parameters
  const schoolLat = parseFloat("<%= settings.latitude_sekolah %>");
  const schoolLng = parseFloat("<%= settings.longitude_sekolah %>");
  const radiusVal = parseInt("<%= settings.radius_gps_meter %>");

  // Log coordinates
  const latMasuk = "<%= log.latitude_masuk %>" ? parseFloat("<%= log.latitude_masuk %>") : null;
  const lngMasuk = "<%= log.longitude_masuk %>" ? parseFloat("<%= log.longitude_masuk %>") : null;
  const latPulang = "<%= log.latitude_pulang %>" ? parseFloat("<%= log.latitude_pulang %>") : null;
  const lngPulang = "<%= log.longitude_pulang %>" ? parseFloat("<%= log.longitude_pulang %>") : null;

  // Initialize Map
  const map = L.map('detailMap').setView([schoolLat, schoolLng], 16);

  // Add OpenStreetMap tile layer
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
    attribution: '&copy; OpenStreetMap contributors'
  }).addTo(map);

  // Define marker icon colors or styles
  const schoolIcon = L.icon({
    iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-blue.png',
    shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.7.1/images/marker-shadow.png',
    iconSize: [25, 41],
    iconAnchor: [12, 41],
    popupAnchor: [1, -34],
    shadowSize: [41, 41]
  });

  const greenIcon = L.icon({
    iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-green.png',
    shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.7.1/images/marker-shadow.png',
    iconSize: [25, 41],
    iconAnchor: [12, 41],
    popupAnchor: [1, -34],
    shadowSize: [41, 41]
  });

  const redIcon = L.icon({
    iconUrl: 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-red.png',
    shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.7.1/images/marker-shadow.png',
    iconSize: [25, 41],
    iconAnchor: [12, 41],
    popupAnchor: [1, -34],
    shadowSize: [41, 41]
  });

  // Group of map markers
  const markers = [];

  // Add School Marker & Circle
  const schoolMarker = L.marker([schoolLat, schoolLng], { icon: schoolIcon }).addTo(map)
    .bindPopup("<b>Sekolah (Pusat Koordinat)</b>");
  markers.push(schoolMarker);

  L.circle([schoolLat, schoolLng], {
    color: '#0d6efd',
    fillColor: '#0d6efd',
    fillOpacity: 0.15,
    radius: radiusVal
  }).addTo(map);

  // Add check-in (Masuk) marker if exists
  if (latMasuk && lngMasuk) {
    const checkinMarker = L.marker([latMasuk, lngMasuk], { icon: greenIcon }).addTo(map)
      .bindPopup("<b>Lokasi Masuk</b><br>Jarak: " + Math.round("<%= log.jarak_masuk %>") + "m dari sekolah");
    markers.push(checkinMarker);
  }

  // Add check-out (Pulang) marker if exists
  if (latPulang && lngPulang) {
    const checkoutMarker = L.marker([latPulang, lngPulang], { icon: redIcon }).addTo(map)
      .bindPopup("<b>Lokasi Pulang</b><br>Jarak: " + Math.round("<%= log.jarak_pulang %>") + "m dari sekolah");
    markers.push(checkoutMarker);
  }

  // Auto-fit maps zoom boundary
  if (markers.length > 1) {
    const group = new L.featureGroup(markers);
    map.fitBounds(group.getBounds().pad(0.15));
  }
</script>

<%- include('../../partials/footer') %>
