<%- include('../../partials/header') %>

<div class="container py-2" style="max-width: 900px;">
  <!-- Header Bar -->
  <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
    <div>
      <h4 class="fw-bold mb-0 text-primary"><i class="fa-solid fa-users me-2"></i> Manajemen Siswa</h4>
      <p class="text-muted mb-0 small">Kelola Akun Akses & Data Kelas Siswa</p>
    </div>
  </div>

  <!-- Main Card Table -->
  <div class="card border-0 shadow-sm bg-white" style="border-radius: 16px;">
    <div class="card-header border-0 bg-transparent pt-4 px-4 pb-0 d-flex justify-content-between align-items-center">
      <h6 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-list text-muted me-2"></i>Daftar Siswa Terdaftar</h6>
      <a href="/admin/siswa/tambah" class="btn btn-primary btn-sm px-3 rounded-pill fw-semibold shadow-sm">
        <i class="fa-solid fa-plus me-1"></i> Tambah Siswa
      </a>
    </div>
    <div class="card-body p-3">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" style="font-size: 13.5px;">
          <thead class="table-light text-secondary small text-uppercase">
            <tr>
              <th style="width: 5%;" class="text-center">No</th>
              <th style="width: 30%;">Nama Lengkap</th>
              <th style="width: 25%;">Username / NIS</th>
              <th style="width: 15%;" class="text-center">Kelas</th>
              <th style="width: 15%;">No. HP</th>
              <th style="width: 10%;" class="text-center">Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% if (siswa && siswa.length > 0) { %>
              <% siswa.forEach((s, index) => { %>
                <tr>
                  <td class="text-center text-secondary"><%= index + 1 %></td>
                  <td>
                    <span class="fw-semibold text-dark"><%= s.nama_lengkap %></span>
                  </td>
                  <td class="font-monospace text-secondary"><%= s.username %></td>
                  <td class="text-center">
                    <span class="badge bg-secondary-subtle text-secondary px-2.5 py-1.5" style="border-radius: 6px;"><%= s.kelas %></span>
                  </td>
                  <td class="text-secondary"><%= s.no_hp || '-' %></td>
                  <td class="text-center">
                    <div class="d-flex justify-content-center gap-1">
                      <a href="/admin/siswa/edit/<%= s.id %>" class="btn btn-sm btn-outline-warning p-1 px-2" style="border-radius: 6px;" title="Ubah Detail">
                        <i class="fa-solid fa-pen-to-square"></i>
                      </a>
                      <button class="btn btn-sm btn-outline-danger p-1 px-2" style="border-radius: 6px;" onclick="confirmDelete('<%= s.id %>', '<%= s.nama_lengkap %>')" title="Hapus Siswa">
                        <i class="fa-solid fa-trash-can"></i>
                      </button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="6" class="text-center text-muted py-4">Belum ada data siswa terdaftar.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  function confirmDelete(id, nama) {
    Swal.fire({
      title: 'Hapus Siswa?',
      text: `Data siswa "${nama}" beserta seluruh log kehadirannya akan dihapus secara permanen!`,
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#dc3545',
      cancelButtonColor: '#6c757d',
      confirmButtonText: 'Ya, Hapus!',
      cancelButtonText: 'Batal'
    }).then((result) => {
      if (result.isConfirmed) {
        window.location.href = `/api/admin/siswa/delete/${id}`;
      }
    });
  }

  // Handle flash messages via URL query params
  const urlParams = new URLSearchParams(window.location.search);
  const status = urlParams.get('status');
  if (status) {
    let title = 'Berhasil!';
    let text = '';
    if (status === 'sukses') {
      text = 'Data siswa baru berhasil ditambahkan.';
    } else if (status === 'diperbarui') {
      text = 'Perubahan data siswa berhasil disimpan.';
    } else if (status === 'dihapus') {
      title = 'Terhapus!';
      text = 'Data siswa telah dihapus secara permanen.';
    }

    if (text) {
      Swal.fire({
        icon: 'success',
        title: title,
        text: text,
        showConfirmButton: false,
        timer: 2000
      });
      window.history.replaceState(null, null, window.location.pathname);
    }
  }
</script>

<%- include('../../partials/footer') %>
