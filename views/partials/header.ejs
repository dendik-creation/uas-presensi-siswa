<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'EPresensi - Sistem Presensi Siswa' %></title>
  <!-- Bootstrap 5 CSS (Light mode default) -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- FontAwesome Icons -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <!-- SweetAlert2 -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Inter', sans-serif;
      background-color: #f8f9fa;
      color: #212529;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    .navbar {
      border-bottom: 1px solid #dee2e6;
      background-color: #ffffff !important;
    }
    footer {
      border-top: 1px solid #dee2e6;
      background-color: #ffffff;
      padding: 1.5rem 0;
      margin-top: auto;
      color: #6c757d;
    }
  </style>
</head>
<body>

  <!-- Navbar (Only rendered if user is authenticated) -->
  <% if (typeof user !== 'undefined' && user) { %>
    <nav class="navbar navbar-expand-lg navbar-light bg-light py-3 mb-4">
      <div class="container">
        <a class="navbar-brand d-flex align-items-center" href="/">
          <i class="fa-solid fa-graduation-cap me-2 text-primary"></i>
          <span class="fw-bold">EPresensi</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto">
            <% if (user.role === 'admin') { %>
              <li class="nav-item">
                <a class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active fw-bold text-primary' : '' %>" href="/">
                  <i class="fa-solid fa-chart-line me-1"></i> Dashboard
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'siswa' ? 'active fw-bold text-primary' : '' %>" href="/admin/siswa">
                  <i class="fa-solid fa-users me-1"></i> Data Siswa
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'presensi' ? 'active fw-bold text-primary' : '' %>" href="/admin/presensi">
                  <i class="fa-solid fa-clipboard-user me-1"></i> Rekap Presensi
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'pengaturan' ? 'active fw-bold text-primary' : '' %>" href="/admin/pengaturan">
                  <i class="fa-solid fa-gears me-1"></i> Pengaturan
                </a>
              </li>
            <% } else if (user.role === 'siswa') { %>
              <li class="nav-item">
                <a class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active fw-bold text-primary' : '' %>" href="/">
                  <i class="fa-solid fa-house me-1"></i> Dashboard
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'presensi' ? 'active fw-bold text-primary' : '' %>" href="/presensi">
                  <i class="fa-solid fa-clipboard-user me-1"></i> Riwayat Presensi
                </a>
              </li>
            <% } %>
          </ul>

          <div class="dropdown">
            <button class="btn btn-outline-dark btn-sm dropdown-toggle d-flex align-items-center gap-2" type="button" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
              <i class="fa-solid fa-user-circle fs-5"></i>
              <span><%= user.nama %></span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm" aria-labelledby="userDropdown">
              <li class="px-3 py-2">
                <div class="text-secondary small">Halo,</div>
                <div class="fw-bold text-dark"><%= user.nama %></div>
                <span class="badge bg-secondary text-capitalize mt-1"><%= user.role %></span>
              </li>
              <li><hr class="dropdown-divider"></li>
              <li>
                <a class="dropdown-item" href="/profile">
                  <i class="fa-solid fa-user me-2 text-primary text-opacity-75"></i>Profil Saya
                </a>
              </li>
              <li><hr class="dropdown-divider"></li>
              <li>
                <a class="dropdown-item text-danger" href="/logout" onclick="confirmLogout(event)">
                  <i class="fa-solid fa-right-from-bracket me-2"></i>Keluar
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </nav>
    <script>
      function confirmLogout(event) {
        event.preventDefault();
        Swal.fire({
          title: 'Keluar?',
          text: 'Wak, Anda perlu login lagi nantinya',
          icon: 'warning',
          showCancelButton: true,
          confirmButtonColor: '#0d6efd',
          cancelButtonColor: '#6c757d',
          confirmButtonText: 'Ya, Keluar!',
          cancelButtonText: 'Batal'
        }).then((result) => {
          if (result.isConfirmed) {
            window.location.href = '/logout';
          }
        });
      }
    </script>
  <% } %>

  <div class="container flex-grow-1">
